{
  "manifest_version": 3,
  "name": "Telegram Link Saver",
  "version": "1.0",
  "description": "Send the current tab URL to your Telegram Saved Messages.",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Save to Telegram"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
